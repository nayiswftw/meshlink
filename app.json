{
  "expo": {
    "name": "Meshlink",
    "slug": "meshlink",
    "scheme": "meshlink",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0F172A"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#6366F1"
        }
      ],
      "expo-font"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.meshlink.app",
      "permissions": [
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_ADVERTISE",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.meshlink.app",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "Meshlink uses Bluetooth to discover and communicate with nearby devices.",
        "NSBluetoothPeripheralUsageDescription": "Meshlink uses Bluetooth to communicate with nearby devices.",
        "NSMicrophoneUsageDescription": "Meshlink needs microphone access to send voice messages.",
        "UIBackgroundModes": [
          "bluetooth-central",
          "bluetooth-peripheral"
        ]
      }
    },
    "extra": {
      "eas": {
        "projectId": "7af64064-fbc3-4646-95f5-d29068574cb4"
      }
    }
  }
}
